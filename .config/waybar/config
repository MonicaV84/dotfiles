{
    "layer": "top", 
    "position": "top", 
    "spacing": 4, 
    "width": 1350,
    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": ["mpd"],
    "modules-right": [
        "idle_inhibitor",
        "custom/notification",
        "pulseaudio",
        "tray",
        "cpu",
        "memory",
        "temperature",
        "custom/pacman",
        "clock"
    ],
    "hyprland/workspaces": {
  "format": "{icon}",
  "on-click": "activate",
  "format-icons": {
    "1": "яДа",
    "2": "яЙй",
    "3": "яДб",
    "4": "яЖ╝",
    "5": "яИ▓",
    "6": "яОТ",
    "7": "яГа",
    "urgent": "яБк",
    "active": "ґ░Ка",
    "default": "яДС"
  },
    "persistent_workspaces": {
    "1": "яДа",
    "2": "яЙй",
    "3": "яДб",
    "4": "яЖ╝",
    "5": "яИ▓",
    "6": "яОТ",
    "7": "яГа",
    }
},
    
"mpd": {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) яАБ",
    "format-disconnected": "Disconnected яАБ",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon} Stopped яАБ",
    "interval": 10,
    "consume-icons": {
        "on": "яГД " // Icon shows only when "consume" is on
    },
    "random-icons": {
        "off": "<span color=\"#f77698\">яБ┤</span> ", // Icon grayed out when "random" is off
        "on": "яБ┤ "
    },
    "repeat-icons": {
        "on": "яАЮ "
    },
    "single-icons": {
        "on": "яАЮ1 "
    },
    "state-icons": {
        "paused": "яБМ",
        "playing": "яБЛ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
},   
    
    "clock": {
        
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "{usage}% яЛЫ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% яГЙ"
    },
    "temperature": {
         "thermal-zone": 2,
         "hwmon-path": ["/sys/class/hwmon/hwmon1/temp1_input"],
         "critical-threshold": 80,
         "format-critical": "{temperatureC}┬░C яЛЗ",
        "format": "{temperatureC}┬░C яЛЙ"
    },
    
    "pulseaudio": {
        
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": [
                "яАж",
                "яАз",
                "яАи"
            ]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "ignored-sinks": ["Easy Effects Sink"]
        
        
    },
    "hyprland/window": {
        "format": "{title}",
        "max-length": 30,
        "rewrite": {
           "(.*) - Mozilla Firefox": "ЁЯМО $1",
           "(.*) - vim": "юЯЕ $1",
           "(.*) - zsh": "яДа [$1]"
        }
    },

    "tray":{
        "icon-size": 15,
        "spacing": 10
    },
    "custom/pacman": {
        "format": "{icon}{}",
        "return-type": "json",
        "format-icons": {
          "pending-updates": "яАЩ ",
          "updated": "яБЭ"
          
        },
        "exec-if": "which waybar-updates",
        "exec": "waybar-updates"
      },
    "custom/notification": {
        "format": "яГ│",
        "on-click": "~/.config/swaync/scripts/notifyme.sh",
        "on-click-right": "~/.config/swaync/scripts/clear.sh",
        "tooltip": false
       

    },

"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "яБо",
        "deactivated": "яБ░"
    }
},
   
  "custom/launcher": {
      "format": "ґ░гЗ",
      "on-click": "wofi --show=drun --allow-images"
    }
}
